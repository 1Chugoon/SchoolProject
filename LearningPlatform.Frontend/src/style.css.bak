  .settings-table .left-panel { padding: 6px 8px; min-height: 44px; gap: 6px; }
}


/* Mobile tweaks for UserPage */
@media (max-width: 768px) {
  .user-page {
    padding: 0 12px 24px;
    box-sizing: border-box;
  }

  .black-container {
    padding: 16px 12px;
  }
  .black-container-content {
    margin-inline: 0;
  }
  .black-container-content p {
    font-size: 0.95rem;
    margin-bottom: 6px;
  }
  .black-container-content h1 {
    font-size: 1.6rem;
    line-height: 1.2;
    margin: 0 0 8px;
    word-break: break-word;
  }

  /* Make profile card static, centered and compact */
  .user-info-container {
    position: static;
    right: auto;
    top: auto;
    width: 100%;
    max-width: 920px;
    margin: 12px 0;
    padding: 14px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    box-shadow: 0 8px 20px rgba(0,0,0,0.06);
    border-radius: 12px;
    background: #fff;
    box-sizing: border-box;
  }
  .user-info-container img {
    width: 96px;
    height: 96px;
    margin: 0;
    border-radius: 50%;
    object-fit: cover;
  }

  .user-info-container .null-btn,
  .user-info-container .purple-btn {
    width: 100%;
    max-width: 360px;
    padding: 10px 14px;
    border-radius: 10px;
  }

  /* Courses list — full width cards */
  .user-courses-section {
    padding: 8px 0 40px;
  }
  .courses-list {
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
    width: 100%;
    box-sizing: border-box;
  }
  .courses-list > li {
    width: 100%;
  }

  /* CourseCard adjustments for mobile */
  .course-card {
    flex-direction: column;
    gap: 10px;
    align-items: stretch;
    padding: 12px;
    border-radius: 10px;
    border: 1px solid rgba(0,0,0,0.06);
    background: #fff;
  }
  .course-card img {
    width: 100%;
    height: auto;
    margin: 0;
    border-radius: 8px;
    object-fit: cover;
  }
  .course-card-content { padding-right: 0; }

  /* Reduce large margins from other rules that push content down */
  .container-main-page-course,
  .main-page,
  .edit-course-box { padding-top: 0; }

  /* Ensure header area not too tall on mobile */
  .black-container { padding-bottom: 8px; }
}

/* Extra small phones */
@media (max-width: 420px) {
  .black-container-content h1 { font-size: 1.35rem; }
  .user-info-container { padding: 10px; }
  .user-info-container img { width: 80px; height: 80px; }
  .user-info-container .null-btn { padding: 9px; }
  .course-card { padding: 10px; }
}